generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model video {
  id             String   @id @default(cuid())
  title          String
  description    String?
  publicId       String
  originalSize   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  compressedSize String
  duration       Int
}
